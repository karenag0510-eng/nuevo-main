{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "create-react-app"
    },
    "backend": {
      "root": "backend",
      "buildCommand": "pip install -r requirements.txt",
      "command": "python -m uvicorn server:app --host 0.0.0.0 --port 8000"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/$1"
    }
  ]
}